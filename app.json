{
  "expo": {
    "name": "FlowLens",
    "slug": "flowlens",
    "version": "1.0.0",
    "orientation": "portrait",
    "scheme": "flowlens",
    "userInterfaceStyle": "automatic",
    "newArchEnabled": false,
    "splash": {
      "resizeMode": "contain",
      "backgroundColor": "#ffffff"
    },
    "ios": {
      "supportsTablet": true,
      "infoPlist": {
        "NSMicrophoneUsageDescription": "FlowLens needs microphone access to record voice reviews for transcription."
      }
    },
    "android": {
      "adaptiveIcon": { "backgroundColor": "#ffffff" },
      "permissions": ["RECORD_AUDIO"]
    },
    "web": {
      "bundler": "metro",
      "output": "single"
    },
    "plugins": ["expo-router"],
    "experiments": {
      "typedRoutes": true
    }
  }
}
